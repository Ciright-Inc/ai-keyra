# ai.keyra.ie — Autonomous Operational Trust Infrastructure
NEXT_PUBLIC_SITE_URL=https://ai.keyra.ie

# Keyra marketing CMS (footer + 9-dot launcher proxy upstream)
NEXT_PUBLIC_KEYRA_MARKETING_ORIGIN=https://keyra.ie
NEXT_PUBLIC_KEYRA_SITE_URL=https://keyra.ie
# Footer scope on keyra.ie CMS (must match admin site app id)
NEXT_PUBLIC_KEYRA_FOOTER_SITE_APP_ID=ai-aoti
