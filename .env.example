# NEXT_PUBLIC_KEYRA_LAUNCHER_APPS_URL=https://keyra.ie/api/deployments/apps/launcher

# Ecosystem app URLs (9-dot launcher + footer)
NEXT_PUBLIC_GET_STARTED_URL=https://get-started.keyra.ie
